# FinSight AI — Production Environment Variables
# Copy this as your reference when setting Railway environment variables.
# DO NOT commit actual values to git.

# ─── AI Provider ───────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=                    # Get from https://aistudio.google.com/apikey
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GROQ_API_KEY=                      # Get from https://console.groq.com

# ─── Database (Neon PostgreSQL) ─────────────────
# Get from https://neon.tech → Project → Connection string
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.neon.tech/finsight?sslmode=require

# ─── Redis (Upstash) ────────────────────────────
# Get from https://console.upstash.com → Redis → Connect
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# ─── Qdrant Cloud ───────────────────────────────
# Get from https://cloud.qdrant.io → Cluster → API Keys
QDRANT_HOST=xxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=                    # Required for Qdrant Cloud
QDRANT_VECTOR_SIZE=3072
QDRANT_COLLECTION=document_chunks

# ─── Security ───────────────────────────────────
JWT_SECRET=                        # Generate: python -c "import secrets; print(secrets.token_hex(32))"

# ─── File Storage ───────────────────────────────
UPLOAD_DIR=/app/uploads

# ─── Model Selection ────────────────────────────
GENERATION_MODEL=gemini-2.5-flash
UTILITY_MODEL=gemini-2.5-flash
GRADER_MODEL=gemini-2.5-flash
PAL_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── Voice ──────────────────────────────────────
STT_MODEL=gemini-2.5-flash
TTS_MODEL=gemini-2.5-flash
TTS_VOICE=Kore
ENABLE_VOICE=true

# ─── CORS (set to your Vercel URL after deploying frontend) ─
CORS_ORIGINS=["https://your-app.vercel.app","https://your-custom-domain.com"]

# ─── Pipeline ───────────────────────────────────
RETRIEVAL_THRESHOLD=0.5
CHAT_HISTORY_LIMIT=6
SUPPORTED_LANGUAGES=["en","hi","gu","mr"]
CHART_KEYWORDS=["revenue","growth","trend","chart","plot","quarterly","annual"]
TABLE_KEYWORDS=["table","compare","list","segments","breakdown","distribution"]

# ─── Feature Flags ──────────────────────────────
ENABLE_PROMPT_CACHING=true
ENABLE_SLM_COMPRESSION=true
DEBUG_MODE=false

# ─── BM25 Index ─────────────────────────────────
BM25_INDEX_DIR=/app/data/bm25_indexes
